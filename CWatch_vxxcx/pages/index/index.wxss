page {
  background: #f3f5f8;
  color: #1f2937;
}

.page {
  padding: 24rpx;
  box-sizing: border-box;
}

.top-card,
.section-card,
.stat-card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.06);
}

.top-card {
  padding: 28rpx;
  background: linear-gradient(135deg, #1f3552 0%, #29486f 100%);
}

.top-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.brand {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.68);
  letter-spacing: 2rpx;
}

.page-title {
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

.status-pill {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.status-on {
  background: rgba(52, 211, 153, 0.18);
  color: #d1fae5;
}

.status-off {
  background: rgba(255, 255, 255, 0.14);
  color: #e5edf8;
}

.top-status {
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.08);
}

.status-line {
  margin-bottom: 18rpx;
}

.status-line:last-child {
  margin-bottom: 0;
}

.status-name {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.62);
}

.status-text {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #ffffff;
  word-break: break-all;
}

.stats-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.stat-card {
  flex: 1;
  padding: 24rpx;
}

.accent-blue {
  background: linear-gradient(135deg, #eef6ff 0%, #ffffff 100%);
}

.accent-orange {
  background: linear-gradient(135deg, #fff5ea 0%, #ffffff 100%);
}

.stat-label {
  font-size: 22rpx;
  color: #6b7280;
}

.stat-value {
  margin-top: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.4;
}

.small-text {
  font-size: 24rpx;
  font-weight: 600;
}

.section-card {
  margin-top: 20rpx;
  padding: 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.section-tip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #375dfb;
  font-size: 22rpx;
}

.warm-tip {
  background: #fff3e6;
  color: #dd6b20;
}

.btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.primary-btn,
.secondary-btn {
  flex: 1;
  margin: 0;
  border-radius: 18rpx;
  font-size: 28rpx;
}

.primary-btn {
  background: #17c964 !important;
  color: #ffffff !important;
}

.secondary-btn {
  background: #f3f4f6 !important;
  color: #111827 !important;
  border: 1rpx solid #e5e7eb;
}

.sync-banner {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.sync-active {
  background: #e8f7ee;
  color: #157347;
}

.sync-idle {
  background: #f6f7fb;
  color: #4b5563;
}

.manual-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
}

.mini-btn {
  width: calc(50% - 8rpx);
  margin: 0;
  border-radius: 18rpx;
  font-size: 26rpx;
  color: #1f2937 !important;
  background: #f8fafc !important;
  border: 1rpx solid #e5e7eb;
}

.device-item {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
}

.device-info {
  flex: 1;
  min-width: 0;
}

.device-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.device-id {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #6b7280;
  word-break: break-all;
}

.device-side {
  flex-shrink: 0;
  text-align: right;
}

.device-rssi {
  font-size: 22rpx;
  color: #6b7280;
}

.device-action {
  margin-top: 10rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #ffffff;
  font-size: 22rpx;
}

.empty-box {
  margin-top: 18rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  text-align: center;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.empty-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}
